---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPosts, formatDate } from '../../lib/content';

const posts = await getPosts();
---

<BaseLayout
  title="Writing"
  description="Notes on building software without an engineering background, what accounting teaches you about data modelling, and where AI actually helps."
>
  <section class="container-page pt-16 pb-12">
    <h1 class="max-w-2xl text-4xl leading-tight sm:text-5xl">Writing</h1>
    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-muted">
      Mostly about the seam between finance and software — what carries over,
      what does not, and what I got wrong on the way.
    </p>
  </section>

  <section class="container-page border-t border-line py-12">
    {
      posts.length === 0 ? (
        <p class="text-muted">First post is on its way.</p>
      ) : (
        <ul class="divide-y divide-line">
          {posts.map((post) => (
            <li class="group relative py-7 first:pt-0">
              <p class="font-mono text-xs text-muted">
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDate(post.data.pubDate)}
                </time>
              </p>

              <h2 class="mt-2 text-xl">
                <a
                  href={`/writing/${post.id}`}
                  class="after:absolute after:inset-0 after:content-[''] group-hover:text-accent-ink"
                >
                  {post.data.title}
                </a>
              </h2>

              <p class="mt-2 max-w-2xl leading-relaxed text-muted">
                {post.data.description}
              </p>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>

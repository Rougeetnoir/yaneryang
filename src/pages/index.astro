---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { site } from '../config/site';
import { getProjects, getPosts, formatDate } from '../lib/content';

const featured = (await getProjects()).slice(0, 3);
const latestPosts = (await getPosts()).slice(0, 2);
---

<BaseLayout personSchema>
  <section class="container-page pt-20 pb-16 sm:pt-28">
    <h1 class="max-w-3xl">
      <span class="block font-mono text-xs tracking-[0.2em] text-muted uppercase">
        {site.name}
      </span>
      <span class="mt-5 block text-4xl leading-[1.1] sm:text-5xl lg:text-[3.5rem]">
        {site.headline}
      </span>
    </h1>

    <p class="mt-7 max-w-2xl text-lg leading-relaxed text-muted">
      {site.subheadline}
    </p>

    <div class="mt-9 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm">
      <a
        href="/projects"
        class="rounded-full bg-accent px-5 py-2.5 font-medium text-ink transition-opacity hover:opacity-85"
      >
        See the work
      </a>
      <a href="/resume" class="text-accent-ink underline-offset-4 hover:underline">
        Read the résumé
      </a>
      <a
        href={`mailto:${site.contact.email}`}
        class="text-accent-ink underline-offset-4 hover:underline"
      >
        Get in touch
      </a>
    </div>
  </section>

  <section class="container-page border-t border-line py-16" aria-labelledby="pillars">
    <h2 id="pillars" class="sr-only">What I bring</h2>

    <div class="grid gap-10 sm:grid-cols-3 sm:gap-8">
      {
        site.pillars.map((pillar, index) => (
          <div>
            <span class="font-mono text-xs text-accent-ink" aria-hidden="true">
              {String(index + 1).padStart(2, '0')}
            </span>
            <h3 class="mt-3 text-lg leading-snug">{pillar.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-muted">{pillar.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="container-page border-t border-line py-16" aria-labelledby="featured">
    <div class="flex items-baseline justify-between gap-6">
      <h2 id="featured" class="text-2xl">Selected work</h2>
      <a
        href="/projects"
        class="text-sm text-accent-ink underline-offset-4 hover:underline"
      >
        All projects
      </a>
    </div>

    <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        featured.map((project) => (
          <ProjectCard
            title={project.data.title}
            summary={project.data.summary}
            period={project.data.period}
            stack={project.data.stack}
            href={`/projects/${project.id}`}
          />
        ))
      }
    </div>
  </section>

  <section class="container-page border-t border-line py-16" aria-labelledby="writing">
    <div class="flex items-baseline justify-between gap-6">
      <h2 id="writing" class="text-2xl">Writing</h2>
      <a
        href="/writing"
        class="text-sm text-accent-ink underline-offset-4 hover:underline"
      >
        All posts
      </a>
    </div>

    <ul class="mt-8 divide-y divide-line">
      {
        latestPosts.map((post) => (
          <li class="group relative py-6 first:pt-0">
            <p class="font-mono text-xs text-muted">
              <time datetime={post.data.pubDate.toISOString()}>
                {formatDate(post.data.pubDate)}
              </time>
            </p>
            <h3 class="mt-2 text-xl">
              <a
                href={`/writing/${post.id}`}
                class="after:absolute after:inset-0 after:content-[''] group-hover:text-accent-ink"
              >
                {post.data.title}
              </a>
            </h3>
            <p class="mt-2 max-w-2xl leading-relaxed text-muted">
              {post.data.description}
            </p>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

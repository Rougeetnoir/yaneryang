---
import { render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import DemoEmbed from '../../components/DemoEmbed.astro';
import { getProjects } from '../../lib/content';

export const getStaticPaths = (async () => {
  const projects = await getProjects();
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}) satisfies GetStaticPaths;

const { project } = Astro.props;
const { Content } = await render(project);
const { title, summary, period, role, stack, links, demo } = project.data;
---

<BaseLayout title={title} description={summary}>
  <article class="container-page pt-16 pb-8">
    <header class="max-w-3xl">
      <p class="font-mono text-xs tracking-wide text-muted">{period}</p>
      <h1 class="mt-3 text-4xl leading-tight sm:text-5xl">{title}</h1>
      <p class="mt-5 text-lg leading-relaxed text-muted">{summary}</p>

      {role && <p class="mt-4 text-sm text-muted">Role: {role}</p>}

      <ul class="mt-6 flex flex-wrap gap-1.5">
        {
          stack.map((tech) => (
            <li class="rounded-full bg-accent-soft px-2.5 py-1 font-mono text-[0.6875rem] text-ink">
              {tech}
            </li>
          ))
        }
      </ul>

      {
        (links.repo || links.live) && (
          <div class="mt-6 flex flex-wrap gap-x-6 gap-y-2 text-sm">
            {links.live && (
              <a
                href={links.live}
                target="_blank"
                rel="noopener noreferrer"
                class="text-accent-ink underline-offset-4 hover:underline"
              >
                Open the app ↗
              </a>
            )}
            {links.repo && (
              <a
                href={links.repo}
                target="_blank"
                rel="noopener noreferrer"
                class="text-accent-ink underline-offset-4 hover:underline"
              >
                Source on GitHub ↗
              </a>
            )}
          </div>
        )
      }
    </header>

    {demo && <DemoEmbed url={demo.url} aspect={demo.aspect} title={title} />}

    <div class="prose prose-site mt-12 max-w-2xl">
      <Content />
    </div>

    <p class="mt-16 border-t border-line pt-8 text-sm">
      <a href="/projects" class="text-accent-ink underline-offset-4 hover:underline">
        ← All projects
      </a>
    </p>
  </article>
</BaseLayout>

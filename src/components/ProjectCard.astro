---
interface Props {
  title: string;
  summary: string;
  period: string;
  stack: readonly string[];
  href: string;
}

const { title, summary, period, stack, href } = Astro.props;
---

<article
  class="group relative flex flex-col rounded-card border border-line bg-surface p-6 shadow-card transition-transform duration-200 hover:-translate-y-0.5"
>
  <p class="font-mono text-xs tracking-wide text-muted">{period}</p>

  <h3 class="mt-2 text-xl">
    <a href={href} class="after:absolute after:inset-0 after:content-['']">
      {title}
    </a>
  </h3>

  <p class="mt-3 flex-1 text-sm leading-relaxed text-muted">{summary}</p>

  <ul class="mt-5 flex flex-wrap gap-1.5">
    {
      stack.map((tech) => (
        <li class="rounded-full bg-accent-soft px-2.5 py-1 font-mono text-[0.6875rem] text-ink">
          {tech}
        </li>
      ))
    }
  </ul>
</article>

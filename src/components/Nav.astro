---
import { site } from '../config/site';

const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path.startsWith(`${href}/`);
---

<header class="border-b border-line">
  {/* Wraps to two rows below ~360px, where the brand and four links stop fitting. */}
  <div
    class="container-page flex min-h-16 flex-wrap items-center justify-between gap-x-4 gap-y-1 py-3 sm:gap-x-6 sm:py-0"
  >
    <a
      href="/"
      class="font-display text-lg whitespace-nowrap text-ink transition-opacity hover:opacity-70"
      aria-label={`${site.name} — home`}
    >
      {site.name}
    </a>

    <nav aria-label="Main">
      <ul class="flex items-center gap-4 text-[0.8125rem] sm:gap-7 sm:text-sm">
        {
          site.nav.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
                class:list={[
                  'transition-colors hover:text-ink',
                  isActive(item.href) ? 'text-ink' : 'text-muted',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
